VERSION=debugging
GLAB_TOKEN=your_gitlab_token_here
NEW_RELIC_API_KEY=your_new_relic_api_key_here
OTEL_EXPORTER_OTEL_ENDPOINT=https://otlp.nr-data.net:4318
OTEL_EXPORTER_TYPE=otlp
GLAB_EXPORT_LOGS=True
GLAB_ENDPOINT=https://gitlab.com
LOG_LEVEL=INFO

# Attribute truncation — prevents data loss from exceeding New Relic attribute limits
# GitLab log records can have 50-100+ attributes after JSON flattening; NR drops records that exceed limits
OTEL_ATTRIBUTE_COUNT_LIMIT=64
OTEL_ATTRIBUTE_VALUE_LENGTH_LIMIT=4096
# Log-record-specific overrides (take precedence over the globals above)
OTEL_LOGRECORD_ATTRIBUTE_COUNT_LIMIT=64
OTEL_LOGRECORD_ATTRIBUTE_VALUE_LENGTH_LIMIT=4096

# BatchLogRecordProcessor tuning — for high-volume exports (1000+ projects)
# OTEL_BLRP_MAX_EXPORT_BATCH_SIZE must be <= OTEL_BLRP_MAX_QUEUE_SIZE
OTEL_BLRP_SCHEDULE_DELAY=2000
OTEL_BLRP_MAX_QUEUE_SIZE=20000
OTEL_BLRP_MAX_EXPORT_BATCH_SIZE=2000
OTEL_EXPORTER_OTLP_TIMEOUT=60000

# Export window — only collect data from last N minutes (recommended: match your pipeline schedule interval)
# Note: code internally adds 1 minute buffer, so 60 -> 61-minute effective window
GLAB_EXPORT_LAST_MINUTES=60
# false = only export data within the GLAB_EXPORT_LAST_MINUTES window (recommended for large instances)
# true = export all historical data (can cause attribute overflow and queue exhaustion on large instances)
GLAB_EXPORT_ALL_PROJECTS=true

# Concurrency tuning — increase for large instances to parallelise API calls
# GLAB_API_WORKERS: thread pool for pipeline/deployment/environment/release list() calls
# GLAB_JOB_WORKERS: thread pool for per-pipeline job fetches (scales with pipeline volume)
# GLAB_EXPORT_BATCH_SIZE: projects processed per batch before draining the OTEL queue
GLAB_API_WORKERS=50
GLAB_JOB_WORKERS=20
GLAB_EXPORT_BATCH_SIZE=100
